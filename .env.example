# ==============================================================================
# AI Investment Intelligence Platform — Environment Variables
# ==============================================================================
# Copy to .env and fill in real values. NEVER commit .env to git.
# ==============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Frontend (Vite env vars must start with VITE_) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- LLM ---
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL_PRIMARY=gpt-4o
LLM_MODEL_BATCH=gpt-4o-mini
LLM_MAX_TOKENS=2000
LLM_MOCK=false

# --- RAG / Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DB=faiss
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# --- Market Data ---
MARKET_DATA_PROVIDER=yfinance
PIPELINE_CRON_HOUR=6
PIPELINE_CRON_MINUTE=0

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173

# --- Redis (optional, for caching) ---
# REDIS_URL=redis://localhost:6379/0
